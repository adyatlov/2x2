    "spacetime:publish": "spacetime publish --module-path spacetimedb --server maincloud"
  },
  "dependencies": {
    "spacetimedb": "^2.1.0",
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "typescript": "~5.6.2",
    "vite": "^7.1.5"
  }
}
